{
	"name": "show-me-ur-agents",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "bun run --filter adhdai build && bun run --filter adhdai-server build",
		"start": "bun run ./packages/cli/src/index.ts",
		"smoke": "bun test packages/cli/tests/smoke-flow.test.ts",
		"publish:version": "bun run --filter adhdai publish:version",
		"review:hourly": "bun run ./packages/cli/src/index.ts cron --job hourly-pr-review",
		"test": "bun test packages/cli/tests && bun run --filter adhdai-server test",
		"typecheck": "bun run --filter adhdai typecheck && bun run --filter adhdai-server typecheck",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"cron:once": "bun run ./packages/cli/src/index.ts cron --once",
		"review:hourly:once": "bun run ./packages/cli/src/index.ts cron --once --job hourly-pr-review",
		"prepare:publish": "bun run --filter adhdai prepare:publish",
		"changeset": "changeset",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.31.0",
		"husky": "^9.1.7"
	}
}
